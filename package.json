{
  "name": "api-mock-gateway",
  "version": "1.0.0",
  "description": "Configurable API mock gateway for testing",
  "main": "dist/server/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/server/index.ts",
    "build": "tsc",
    "start": "node dist/server/index.js",
    "lint": "eslint src/**/*.ts tests/**/*.ts",
    "lint:fix": "eslint src/**/*.ts tests/**/*.ts --fix",
    "test": "jest --passWithNoTests",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:e2e": "jest tests/e2e"
  },
  "keywords": [
    "mock-server",
    "api-mock",
    "api-testing",
    "contract-testing",
    "chaos-engineering",
    "openapi",
    "typescript",
    "express"
  ],
  "author": "Darrius Jones",
  "license": "MIT",
  "dependencies": {
    "ajv": "8.17.1",
    "express": "4.21.2",
    "handlebars": "4.7.8",
    "js-yaml": "4.1.0",
    "uuid": "10.0.0"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/jest": "29.5.14",
    "@types/js-yaml": "4.0.9",
    "@types/node": "20.17.12",
    "@types/uuid": "10.0.0",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "eslint": "8.57.1",
    "jest": "29.7.0",
    "supertest": "7.0.0",
    "@types/supertest": "6.0.2",
    "ts-jest": "29.2.5",
    "ts-node": "10.9.2",
    "ts-node-dev": "2.0.0",
    "typescript": "5.6.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
